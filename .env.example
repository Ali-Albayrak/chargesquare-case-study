# ChargeSquare local compose — copy to .env and adjust. No production secrets.
POSTGRES_USER=chargesquare
POSTGRES_PASSWORD=chargesquare
POSTGRES_DB=chargesquare
DATABASE_URL=postgresql+psycopg://chargesquare:chargesquare@db:5432/chargesquare
STATION_SERVICE_URL=http://station:8001
STATION_PORT=8001
SESSION_PORT=8002
ADMIN_UI_PORT=8080

# Stage 2 auth (demo placeholders only — never commit real secrets)
JWT_SECRET=chargesquare-dev-jwt-secret-change-me-32b

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Local Vite (:5173) and compose admin-ui (:8080).
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
