# Session Service — local uvicorn (non-compose). Copy to .env and adjust.
# For docker compose, use root `.env.example`
# (DB host `db`; STATION_SERVICE_URL host `station`, not localhost).
DATABASE_URL=postgresql+psycopg://chargesquare:chargesquare@localhost:5432/chargesquare
STATION_SERVICE_URL=http://localhost:8001
PORT=8002
